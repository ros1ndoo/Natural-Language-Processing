    "# 9) Visualizaciones\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from wordcloud import WordCloud\n",
    "\n",
    "# Let's map topic indices to keywords for cleaner plots\n",
    "topic_labels = {i: f\"T{i}: {topic_words[i][0]}, {topic_words[i][1]}\" for i in range(N_TOPICS)}\n",
    "\n",
    "df_target['topic_label'] = df_target['dominant_topic'].map(topic_labels)\n",
    "df_comp['topic_label'] = df_comp['dominant_topic'].map(topic_labels)\n",
    "\n",
    "# Chart 1: Overall Sentiment Distribution (Normalized to Percentage)\n",
    "plt.figure(figsize=(8, 5))\n",
    "sentiment_data = pd.DataFrame({\n",
    "    'Group': ['Target (Boohoo)'] * len(df_target) + ['Competitors'] * len(df_comp),\n",
    "    'Sentiment': df_target['sentiment_label'].tolist() + df_comp['sentiment_label'].tolist()\n",
    "})\n",
    "# Calculate percentages within each group\n",
    "sentiment_pct = sentiment_data.groupby(['Group', 'Sentiment']).size().reset_index(name='count')\n",
    "sentiment_totals = sentiment_data.groupby('Group').size().reset_index(name='total')\n",
    "sentiment_pct = sentiment_pct.merge(sentiment_totals, on='Group')\n",
    "sentiment_pct['Percentage'] = (sentiment_pct['count'] / sentiment_pct['total']) * 100\n",
    "\n",
    "sns.barplot(data=sentiment_pct, x='Sentiment', y='Percentage', hue='Group', palette='coolwarm')\n",
    "plt.title('Overall Customer Sentiment: Target vs Competitors')\n",
    "plt.ylabel('Percentage (%)')\n",
    "plt.tight_layout()\n",
    "plt.savefig('sentiment_comparison.png')\n",
    "plt.show()\n",
    "\n",
    "# Chart 2: Topic Distribution Comparison (Normalized to Percentage)\n",
    "plt.figure(figsize=(10, 6))\n",
    "topic_data = pd.DataFrame({\n",
    "    'Group': ['Target (Boohoo)'] * len(df_target) + ['Competitors'] * len(df_comp),\n",
    "    'Topic': df_target['topic_label'].tolist() + df_comp['topic_label'].tolist()\n",
    "})\n",
    "# Calculate percentages within each group\n",
    "topic_pct = topic_data.groupby(['Group', 'Topic']).size().reset_index(name='count')\n",
    "topic_totals = topic_data.groupby('Group').size().reset_index(name='total')\n",
    "topic_pct = topic_pct.merge(topic_totals, on='Group')\n",
    "topic_pct['Percentage'] = (topic_pct['count'] / topic_pct['total']) * 100\n",
    "\n",
    "sns.barplot(data=topic_pct, y='Topic', x='Percentage', hue='Group', palette='viridis', order=[topic_labels[i] for i in range(N_TOPICS)])\n",
    "plt.title('Topics of Conversation: Target vs Competitors')\n",
    "plt.xlabel('Percentage (%)')\n",
    "plt.ylabel('Topic')\n",
    "plt.tight_layout()\n",
    "plt.savefig('topic_distribution.png')\n",
    "plt.show()\n",
    "\n",
    "# Chart 3: Aspect-Based Sentiment Ratio (Positive sentiment ratio per topic)\n",
    "target_topic_sent = df_target.groupby('topic_label')['sentiment'].mean().reset_index()\n",
    "target_topic_sent['Group'] = 'Target (Boohoo)'\n",
    "comp_topic_sent = df_comp.groupby('topic_label')['sentiment'].mean().reset_index()\n",
    "comp_topic_sent['Group'] = 'Competitors'\n",
    "\n",
    "combined_topic_sent = pd.concat([target_topic_sent, comp_topic_sent], ignore_index=True)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.barplot(data=combined_topic_sent, y='topic_label', x='sentiment', hue='Group', palette='RdYlGn', order=[topic_labels[i] for i in range(N_TOPICS)])\n",
    "plt.title('Positive Sentiment Ratio per Topic (Aspect-Based Sentiment)')\n",
    "plt.xlabel('Positive Sentiment Ratio')\n",
    "plt.ylabel('Topic')\n",
    "plt.xlim(0, 1.0)\n",
    "plt.tight_layout()\n",
    "plt.savefig('aspect_sentiment_comparison.png')\n",
    "plt.show()\n",
    "\n",
    "# Chart 4: Word Clouds for each topic\n",
    "fig, axes = plt.subplots(4, 2, figsize=(15, 20))\n",
    "axes = axes.ravel()\n",
    "for topic_idx in range(N_TOPICS):\n",
    "    words_str = \" \".join(topic_words[topic_idx])\n",
    "    wc = WordCloud(background_color='white', width=400, height=200).generate(words_str)\n",
    "    axes[topic_idx].imshow(wc, interpolation='bilinear')\n",
    "    axes[topic_idx].set_title(f\"Topic {topic_idx}: {topic_labels[topic_idx]}\")\n",
    "    axes[topic_idx].axis('off')\n",
    "plt.tight_layout()\n",
    "plt.savefig('topic_wordclouds.png')\n",
    "plt.show()\n"
   ]
