    "# 8) Topic Modeling using TF-IDF and NMF\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.decomposition import NMF\n",
    "\n",
    "print(\"Fitting TF-IDF on combined reviews...\")\n",
    "df_combined = pd.concat([df_target, df_comp], ignore_index=True)\n",
    "\n",
    "vectorizer = TfidfVectorizer(max_df=0.95, min_df=2, stop_words='english')\n",
    "tfidf_matrix = vectorizer.fit_transform(df_combined['clean_review'])\n",
    "\n",
    "print(f\"Fitting NMF with N_TOPICS={N_TOPICS}...\")\n",
    "nmf = NMF(n_components=N_TOPICS, random_seed=42, init='nndsvd') if hasattr(NMF(), 'random_seed') else NMF(n_components=N_TOPICS, random_state=42, init='nndsvd')\n",
    "nmf_matrix = nmf.fit_transform(tfidf_matrix)\n",
    "\n",
    "# Print top words for each topic\n",
    "feature_names = vectorizer.get_feature_names_out()\n",
    "topic_words = {}\n",
    "for topic_idx in range(N_TOPICS):\n",
    "    top_features_ind = nmf.components_[topic_idx].argsort()[:-TOP_WORDS - 1:-1]\n",
    "    top_features = [feature_names[i] for i in top_features_ind]\n",
    "    topic_words[topic_idx] = top_features\n",
    "    print(f\"Topic {topic_idx}: {', '.join(top_features)}\")\n",
    "\n",
    "# Assign dominant topic\n",
    "df_combined['dominant_topic'] = nmf_matrix.argmax(axis=1)\n",
    "\n",
    "# Map back to individual dataframes\n",
    "df_target['dominant_topic'] = df_combined.iloc[:len(df_target)]['dominant_topic'].values\n",
    "df_comp['dominant_topic'] = df_combined.iloc[len(df_target):]['dominant_topic'].values\n"
   ]
  },
