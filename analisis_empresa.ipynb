    "# Analizar qué tipo de caracteres hay en las reseñas para construir la función de limpieza\n",
    "import re\n",
    "from collections import Counter\n",
    "\n",
    "# Contar cuántas reseñas contienen caracteres o patrones especiales\n",
    "total_reviews = len(df)\n",
    "reviews_with_html = df['review'].apply(lambda x: bool(re.search(r'<[^>]*>', str(x)))).sum()\n",
    "reviews_with_urls = df['review'].apply(lambda x: bool(re.search(r'https?://\\S+|www\\.\\S+', str(x)))).sum()\n",
    "reviews_with_emails = df['review'].apply(lambda x: bool(re.search(r'\\S+@\\S+', str(x)))).sum()\n",
    "reviews_with_hashtags = df['review'].apply(lambda x: '#' in str(x)).sum()\n",
    "reviews_with_mentions = df['review'].apply(lambda x: '@' in str(x)).sum()\n",
    "reviews_with_newlines = df['review'].apply(lambda x: '\\n' in str(x)).sum()\n",
    "\n",
    "print(f\"Total de reseñas: {total_reviews}\")\n",
    "print(f\"Reseñas con HTML: {reviews_with_html} ({reviews_with_html / total_reviews * 100:.2f}%)\")\n",
    "print(f\"Reseñas con URLs: {reviews_with_urls} ({reviews_with_urls / total_reviews * 100:.2f}%)\")\n",
    "print(f\"Reseñas con Emails: {reviews_with_emails} ({reviews_with_emails / total_reviews * 100:.2f}%)\")\n",
    "print(f\"Reseñas con Hashtags: {reviews_with_hashtags} ({reviews_with_hashtags / total_reviews * 100:.2f}%)\")\n",
    "print(f\"Reseñas con Menciones (@): {reviews_with_mentions} ({reviews_with_mentions / total_reviews * 100:.2f}%)\")\n",
    "print(f\"Reseñas con Saltos de línea: {reviews_with_newlines} ({reviews_with_newlines / total_reviews * 100:.2f}%)\")\n",
    "\n",
    "# Mostrar algunos ejemplos de caracteres especiales o puntuación no estándar\n",
    "text_combined = \" \".join(df['review'].dropna().astype(str).tolist()[:5000])\n",
    "non_alpha = re.findall(r'[^a-zA-Z\\s]', text_combined)\n",
    "non_alpha_counts = Counter(non_alpha).most_common(30)\n",
    "print(\"\\nCaracteres especiales/puntuación más comunes:\")\n",
    "for char, count in non_alpha_counts:\n",
    "    print(f\"'{char}': {count}\")\n"
   ]
