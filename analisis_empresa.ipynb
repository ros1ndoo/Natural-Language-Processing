    "# 7) Sentiment Analysis using Pre-trained Transformers Pipeline\n",
    "import torch\n",
    "from transformers import pipeline\n",
    "\n",
    "print(\"Loading sentiment model (distilbert-base-uncased-finetuned-sst-2-english)...\")\n",
    "device = 0 if torch.cuda.is_available() else -1\n",
    "classifier = pipeline(\"sentiment-analysis\", model=\"distilbert-base-uncased-finetuned-sst-2-english\", device=device)\n",
    "\n",
    "print(\"Analyzing target company reviews...\")\n",
    "target_texts = df_target['clean_review'].tolist()\n",
    "target_preds = classifier(target_texts, batch_size=16, truncation=True)\n",
    "df_target['sentiment_label'] = [p['label'] for p in target_preds]\n",
    "df_target['sentiment'] = [1 if p['label'] == 'POSITIVE' else 0 for p in target_preds]\n",
    "\n",
    "print(\"Analyzing competitor reviews...\")\n",
    "comp_texts = df_comp['clean_review'].tolist()\n",
    "comp_preds = classifier(comp_texts, batch_size=32, truncation=True)\n",
    "df_comp['sentiment_label'] = [p['label'] for p in comp_preds]\n",
    "df_comp['sentiment'] = [1 if p['label'] == 'POSITIVE' else 0 for p in comp_preds]\n",
    "\n",
    "print(\"Target Positive Sentiment Ratio:\", df_target['sentiment'].mean())\n",
    "print(\"Competitors Positive Sentiment Ratio:\", df_comp['sentiment'].mean())\n"
   ]
  },
